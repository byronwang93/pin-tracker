rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Journal photos are namespaced by uid — only the signed-in owner can
    // read/write their own images.
    match /journal-images/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
